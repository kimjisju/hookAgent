{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${extensionPath}${/}..${/}..${/}scripts${/}gemini_auditor.py\"",
            "name": "hookagent-session-start"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${extensionPath}${/}..${/}..${/}scripts${/}gemini_auditor.py\"",
            "name": "hookagent-session-end"
          }
        ]
      }
    ],
    "BeforeAgent": [
