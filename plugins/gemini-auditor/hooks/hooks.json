        "hooks": [
          {
            "type": "command",
            "command": "python \"${extensionPath}${/}..${/}..${/}scripts${/}gemini_auditor.py\"",
            "name": "hookagent-before-agent"
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "hooks": [
          {
            "type": "command",
